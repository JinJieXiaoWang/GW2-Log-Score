  "normalization_rules": {
    "relative_to_average": {
      "description": "相对于团队平均值的标准化",
      "formula": "clamp((player_value / team_average) * 100, 0, 100)"
    },
    "inverse_relative_to_average": {
      "description": "相对于团队平均值的反向标准化（值越低分数越高）",
      "formula": "clamp((team_average / player_value) * 100, 0, 100)"
    },
    "percentage": {
      "description": "直接使用百分比值",
      "formula": "clamp(value, 0, 100)"
    },
    "fixed": {
      "description": "固定计算公式，不做标准化",
      "formula": "直接使用计算结果"
    }
  }
