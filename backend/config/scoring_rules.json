{
  "_documentation": {
    "description": "GW2评分规则统一配置文件",
    "version": "1.1-WvW-大团专属",
    "last_updated": "2025-01-01",
    "maintainer": "GW2 Log Score Team",
    "_usage": "此文件为评分规则的唯一真实来源，支持按职业-专精定制评分规则",
    "_structure": {
      "version": "评分规则版本号，用于版本追踪",
      "mode": "游戏模式：WvW / PVE",
      "profession_specialization_rules": "职业-专精级别的详细评分规则",
      "fallback_role_rules": "未匹配职业-专精时的角色级别默认规则"
    },
    "_maintenance_guide": {
      "添加新规则": "在 profession_specialization_rules 下添加新的职业-专精键",
      "修改权重": "直接修改对应规则中的 dimension_weights",
      "修改数据源": "修改对应规则中的 data_source 映射",
      "游戏版本更新": "通常只需调整权重或添加/移除评分维度"
    }
  },

  "version": "1.1-WvW-大团专属",

  "mode": "WvW",

  "default_threshold": 80,

  "dimension_definitions": {
    "stability_uptime": {
      "name": "稳固覆盖率",
      "description": "稳固(Stability)buff的覆盖率百分比",
      "data_field": "buffUptimes[Stability]",
      "value_range": [0, 100],
      "normalization": "percentage"
    },
    "resistance_uptime": {
      "name": "抗性覆盖率",
      "description": "抗性(Resistance)buff的覆盖率百分比",
      "data_field": "buffUptimes[Resistance]",
      "value_range": [0, 100],
      "normalization": "percentage"
    },
    "swiftness_uptime": {
      "name": "急速覆盖率",
      "description": "急速(Swiftness)buff的覆盖率百分比",
      "data_field": "buffUptimes[Swiftness]",
      "value_range": [0, 100],
      "normalization": "percentage"
    },
    "regeneration_uptime": {
      "name": "再生覆盖率",
      "description": "再生(Regeneration)buff的覆盖率百分比",
      "data_field": "buffUptimes[Regeneration]",
      "value_range": [0, 100],
      "normalization": "percentage"
    },
    "cleanses": {
      "name": "清症次数",
      "description": "清除症状的次数",
      "data_field": "cleanses",
      "value_range": [0, null],
      "normalization": "relative_to_average",
      "unit": "次"
    },
    "strips": {
      "name": "削增益次数",
      "description": "剥离敌方增益的次数",
      "data_field": "strippedBuffs",
      "value_range": [0, null],
      "normalization": "relative_to_average",
      "unit": "次"
    },
    "breakbar_damage": {
      "name": "破控/控制次数",
      "description": "breakbar伤害和控制技能命中次数",
      "data_field": "breakbarDamage",
      "value_range": [0, null],
      "normalization": "relative_to_average",
      "unit": "次"
    },
    "healing_done": {
      "name": "治疗量",
      "description": "提供的总治疗量",
      "data_field": "healingDone",
      "value_range": [0, null],
      "normalization": "relative_to_average",
      "unit": "点"
    },
    "damage_taken": {
      "name": "承伤量",
      "description": "受到的伤害（越低越好）",
      "data_field": "damageTaken",
      "value_range": [0, null],
      "normalization": "inverse_relative_to_average",
      "unit": "点"
    },
    "damage_per_second": {
      "name": "有效伤害/秒伤",
      "description": "每秒造成的有效伤害",
      "data_field": "damageTargetPerSecond",
      "value_range": [0, null],
      "normalization": "relative_to_average",
      "unit": "伤害/秒"
    },
    "trap_and_insignia_damage_ratio": {
      "name": "陷阱/符印伤害占比",
      "description": "陷阱和符印技能造成的伤害占总伤害的比例",
      "data_field": "trapInsigniaDamageRatio",
      "value_range": [0, 100],
      "normalization": "percentage",
      "unit": "%"
    },
    "spear_skill_damage_ratio": {
      "name": "长矛组技能伤害占比",
      "description": "长矛技能造成的伤害占总伤害的比例",
      "data_field": "spearSkillDamageRatio",
      "value_range": [0, 100],
      "normalization": "percentage",
      "unit": "%"
    },
    "survival_score": {
      "name": "生存表现",
      "description": "基于死亡和倒地的生存评分",
      "data_field": "deaths,downs",
      "calculation": "100 - (deaths * 20 + downs * 10)",
      "value_range": [0, 100],
      "normalization": "fixed"
    },
    "debuff_uptime": {
      "name": "易伤覆盖率",
      "description": "易伤(Vulnerability)debuff的覆盖率",
      "data_field": "debuffUptimes[Vulnerability]",
      "value_range": [0, 100],
      "normalization": "percentage"
    },
    "negated_attacks": {
      "name": "控制次数",
      "description": "通过控制技能无效化敌方攻击的次数",
      "data_field": "negatedAttacks",
      "value_range": [0, null],
      "normalization": "relative_to_average",
      "unit": "次"
    },
    "group_hit_efficiency": {
      "name": "群体命中效率",
      "description": "技能命中敌人数占可命中人数的比例",
      "data_field": "groupHitEfficiency",
      "value_range": [0, 100],
      "normalization": "percentage",
      "unit": "%"
    }
  },

